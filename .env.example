# =====================================================
#  INSTAGRAM AUTO-POST — powerencapsulados
#  Copie este arquivo para .env e preencha os valores
# =====================================================

# --- Meta / Instagram ---
META_APP_ID=1019033761105270
META_APP_SECRET=SEU_APP_SECRET_AQUI
META_REDIRECT_URI=http://localhost:3001/auth/callback
INSTAGRAM_USERNAME=powerencapsulados

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-...

# --- Firebase ---
FIREBASE_PROJECT_ID=seu-projeto-firebase
FIREBASE_PRIVATE_KEY_ID=...
# Caminho para o arquivo de credenciais do Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- Servidor ---
PORT=3001
CLIENT_URL=http://localhost:5173
SESSION_SECRET=uma-string-secreta-aleatoria-aqui

# --- Configurações de postagem ---
DEFAULT_NICHE=capsulas naturais e suplementos
MAX_POSTS_PER_DAY=10
